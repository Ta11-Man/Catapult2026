# MongoDB connection string
# Create a free cluster at mongodb.com/cloud/atlas
MONGODB_URI=mongodb+srv://username:password@cluster-name.mongodb.net/?appName=proof-of-attrition

# Server port
PORT=4000

# World Coin App ID - Register at developer.worldcoin.org
WLD_APP_ID=app_staging_xxxxxxxxxxxxxxxxxxxxxxxx

# World Coin Action ID
WLD_ACTION=submit-cell

# Frontend origin for CORS (leave empty for local development)
# Example for production: https://example.com
ALLOWED_ORIGIN=
